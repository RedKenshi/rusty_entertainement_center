import { ScrollView } from "std-widgets.slint";
import { TreeItem } from "structs.slint";
import { TreeRow } from "rows/tree_row.slint";
import { SpaceRow } from "rows/space_row.slint";
import { IconLoader, FaIcon } from "icon.slint";
import { Colors } from "../theme/colors.slint";

import "../../assets/fonts/PixelifySans-VariableFont_wght.ttf";
import { Spacing } from "../theme/spacing.slint";
import { FileInfos } from "infos/file_infos.slint";
import { FolderInfos } from "infos/folder_infos.slint";
import { VolumeInfos } from "infos/volume_infos.slint";
import { Help } from "help/help.slint";
import { PlayerView } from "player/player_view.slint";

export { TreeItem, IconLoader, Colors }

export component MainWindow inherits Window {
    width: 560px;
    height: 320px;
    background: root.player_active ? #000000 : Colors.primary-5;
    default-font-family: "Pixelify Sans";
    default-font-size: 15px;
    default-font-weight: 600;

    callback move_selection(delta: int);
    callback open_selected();
    callback navigate_back();
    callback cycle_theme();
    callback toggle_help();

    callback playback_toggle_pause();
    callback playback_seek_backward();
    callback playback_seek_forward();
    callback playback_stop();

    in-out property <bool> help_visible: false;
    in-out property <bool> player_active: false;
    in-out property <[TreeItem]> tree;
    in-out property <int> selected_index: 0;
    in-out property <length> scroll_offset: 0px;

    in-out property <string> playback_title: "";
    in-out property <string> playback_time_progress: "0:00";
    in-out property <string> playback_duration: "0:00";
    in-out property <float> playback_progress: 0;
    in-out property <bool> playback_playing: false;
    in-out property <image> playback_video;

    private property <length> top-space: 8px;
    private property <length> bottom-space: 80px;
    private property <length> row-height: 28px;

    pure function item-top(index: int) -> length {
        root.top-space + index * root.row-height
    }

    pure function content-height() -> length {
        if root.tree.length == 0 {
            0px
        } else {
            root.top-space + root.tree.length * root.row-height + root.bottom-space
        }
    }

    private property <length> viewport-height: root.height - 34px;

    private property <TreeItem> selected-item: root.tree.length > 0
        ? root.tree[clamp(root.selected_index, 0, root.tree.length - 1)]
        : {
            name: "",
            format: "",
            codec: "",
            bitrate: "",
            resolution: "",
            size: "",
            indent: 0,
            is_folder: false,
            is_volume: false,
            expanded: false,
            selected: false,
            path: "",
            nbFiles: 0,
            filesSize: "",
            filesDuration: "",
        };

    function update-scroll-to-selection() {
        if root.tree.length == 0 {
            root.scroll_offset = 0px;
            return;
        }

        let viewport_h = root.viewport-height;
        if viewport_h <= 0px {
            return;
        }

        let index = clamp(root.selected_index, 0, root.tree.length - 1);
        let item_top = root.item-top(index);
        let centered = item_top - (viewport_h - root.row-height) / 2;
        let max_offset = max(root.content-height() - viewport_h, 0px);
        root.scroll_offset = clamp(centered, 0px, max_offset);
    }

    changed selected_index => {
        root.update-scroll-to-selection();
    }

    changed tree => {
        root.update-scroll-to-selection();
    }

    changed viewport-height => {
        root.update-scroll-to-selection();
    }

    changed player_active => {
        focus_scope.focus();
    }

    focus_scope := FocusScope {
        width: 100%;
        height: 100%;
        focus-on-click: true;
        focus-on-tab-navigation: true;

        KeyBinding {
            keys: @keys(Space);
            activated => {
                if root.player_active {
                    root.playback_toggle_pause();
                }
            }
        }
        KeyBinding {
            keys: @keys(LeftArrow);
            activated => {
                if root.player_active {
                    root.playback_seek_backward();
                } else {
                    root.navigate_back();
                }
            }
        }
        KeyBinding {
            keys: @keys(RightArrow);
            activated => {
                if root.player_active {
                    root.playback_seek_forward();
                } else {
                    root.open_selected();
                }
            }
        }
        KeyBinding {
            keys: @keys(Escape);
            activated => {
                if root.player_active {
                    root.playback_stop();
                } else {
                    root.navigate_back();
                }
            }
        }
        KeyBinding {
            keys: @keys(Return);
            activated => {
                if !root.player_active {
                    root.open_selected();
                }
            }
        }
        KeyBinding {
            keys: @keys(UpArrow);
            activated => {
                if !root.player_active {
                    root.move_selection(-1);
                }
            }
        }
        KeyBinding {
            keys: @keys(DownArrow);
            activated => {
                if !root.player_active {
                    root.move_selection(1);
                }
            }
        }
        KeyBinding {
            keys: @keys(T);
            activated => {
                if !root.player_active {
                    root.cycle_theme();
                }
            }
        }
        KeyBinding {
            keys: @keys(H);
            activated => {
                if !root.player_active {
                    root.toggle_help();
                }
            }
        }

        Rectangle {
            width: 100%;
            height: 100%;

            if root.player_active: Rectangle {
                width: 100%;
                height: 100%;

                Image {
                    width: 100%;
                    height: 100%;
                    source: root.playback_video;
                    image-fit: cover;
                }

                VerticalLayout {
                    width: 100%;
                    height: 100%;
                    alignment: end;

                    PlayerView {
                        width: 100%;
                        title: root.playback_title;
                        time-progress: root.playback_time_progress;
                        duration: root.playback_duration;
                        progress: root.playback_progress;
                        playing: root.playback_playing;
                    }
                }
            }

            if !root.player_active: VerticalLayout {
                width: 100%;
                height: 100%;

                Rectangle {
                    horizontal-stretch: 1;
                    scroll_view := ScrollView {
                        width: 100%;
                        height: 100%;
                        viewport-y: -root.scroll_offset;

                        VerticalLayout {
                            width: parent.width;
                            spacing: 0;

                            for item[index] in root.tree : VerticalLayout {
                                width: parent.width;
                                spacing: 0;

                                if index == 0 : SpaceRow {
                                    width: parent.width;
                                    space-height: root.top-space;
                                }

                                TreeRow {
                                    width: parent.width;
                                    item: item;
                                }

                                if index == root.tree.length - 1 : SpaceRow {
                                    width: parent.width;
                                    space-height: root.bottom-space;
                                }
                            }
                        }
                    }
                }

                Rectangle {
                    width: parent.width;
                    height: 2px;
                    background: Colors.primary-30;
                }

                Rectangle {
                    width: parent.width;
                    height: 32px;

                    if root.tree.length > 0 && root.selected-item.is_volume : VolumeInfos {
                        width: 100%;
                        height: 100%;

                        name: root.selected-item.name;
                        size: root.selected-item.filesSize;
                        duration: root.selected-item.filesDuration;
                        nbFiles: root.selected-item.nbFiles;
                    }

                    if root.tree.length > 0 && root.selected-item.is_folder && !root.selected-item.is_volume : FolderInfos {
                        width: 100%;
                        height: 100%;

                        name: root.selected-item.name;
                        size: root.selected-item.filesSize;
                        duration: root.selected-item.filesDuration;
                        nbFiles: root.selected-item.nbFiles;
                    }

                    if root.tree.length > 0 && !root.selected-item.is_folder && !root.selected-item.is_volume : FileInfos {
                        width: 100%;
                        height: 100%;

                        bitrate: root.selected-item.bitrate;
                        format: root.selected-item.format;
                        codec: root.selected-item.codec;
                        resolution: root.selected-item.resolution;

                        name: root.selected-item.name;
                        size: root.selected-item.size;
                        duration: root.selected-item.filesDuration;
                    }
                }
            }

            if !root.player_active && help_visible : Help {}
        }
    }
}
