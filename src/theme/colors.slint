// Active monochrome palette — values are set at runtime from Rust (see theme/mod.rs).
// Defaults match the teal phosphor theme so the UI renders before apply_palette runs.

export global Colors {
    in-out property <color> primary-2: #061010;
    in-out property <color> primary-5: #091E1D;
    in-out property <color> primary-10: #0D3531;
    in-out property <color> primary-20: #166259;
    in-out property <color> primary-30: #1F8C7F;
    in-out property <color> primary-40: #27B4A2;
    in-out property <color> primary-50: #2DD4BF;
    in-out property <color> primary-60: #66E1D1;
    in-out property <color> primary-70: #94ECDF;
    in-out property <color> primary-80: #BEF6EC;
    in-out property <color> primary-90: #E6FFF9;
}
